{
  "name": "sst-monorepo-starter",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "pnpm install",
    "clean": "find . -name 'node_modules' -type d -prune -not -path './.git/*' -exec rm -rf '{}' + && rm -f pnpm-lock.yaml",
    "clean:modules": "find . -name 'node_modules' -type d -prune -not -path './.git/*' -exec rm -rf '{}' + && rm -f pnpm-lock.yaml",
    "clean:all": "pnpm -r exec -- rm -rf node_modules 2>/dev/null || true && rm -rf node_modules && rm -f pnpm-lock.yaml",
    "build": "pnpm --filter web build",
    "build:all": "pnpm -r --filter './packages/*' build",
    "dev": "pnpm sst dev",
    "dev:local": "pnpm --filter web dev",
    "deploy": "pnpm sst deploy",
    "deploy:infra": "pnpm sst deploy",
    "remove": "pnpm sst remove",
    "web:dev": "pnpm --filter web dev",
    "web:build": "pnpm --filter web build",
    "lint": "pnpm exec biome check .",
    "lint:fix": "pnpm exec biome check . --write",
    "format": "pnpm exec biome format . --write",
    "typecheck": "pnpm --filter './packages/*' exec -- tsc --noEmit && pnpm --filter web check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "codegen": "pnpm --filter @sst-monorepo/graphql codegen",
    "codegen:watch": "pnpm --filter @sst-monorepo/graphql codegen:watch",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "SST Monorepo Starter Template with Landing Page, Login, and Dashboard",
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "aws-cdk-lib": "^2.221.0",
    "constructs": "^10.4.2",
    "nx": "^22.0.1",
    "sst": "^3.17.24",
    "@pulumi/aws": "^7.12.0",
    "@pulumi/pulumi": "^3.209.0",
    "@types/node": "^24.10.1",
    "zod": "^4.1.13",
    "graphql-request": "^7.3.5",
    "@aws-amplify/auth": "^6.15.7",
    "aws-amplify": "^6.15.7",
    "dotenv": "^17.2.3",
    "vitest": "^4.0.14",
    "@vitest/coverage-v8": "^4.0.14",
    "@playwright/test": "^1.48.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  },
  "packageManager": "pnpm@10.20.0",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.922.0",
    "@aws-sdk/lib-dynamodb": "^3.922.0",
    "@sst-monorepo/graphql": "workspace:*",
    "ulid": "^3.0.1"
  }
}
